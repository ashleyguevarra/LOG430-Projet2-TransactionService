<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<include resource="org/springframework/boot/logging/logback/defaults.xml"/>

	<springProperty name="springAppName" source="spring.application.name" defaultValue="transaction"/>

	<!-- Profil optionnel : logs console lisibles (défaut = JSON structuré pour observabilité / agrégation) -->
	<springProfile name="human">
		<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
			<encoder>
				<pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
				<charset>UTF-8</charset>
			</encoder>
		</appender>
	</springProfile>

	<springProfile name="!human">
		<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
			<encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
				<providers>
					<timestamp>
						<fieldName>@timestamp</fieldName>
						<pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
						<timeZone>UTC</timeZone>
					</timestamp>
					<logLevel>
						<fieldName>level</fieldName>
					</logLevel>
					<loggerName>
						<fieldName>logger</fieldName>
					</loggerName>
					<message/>
					<mdc/>
					<stackTrace>
						<fieldName>stack_trace</fieldName>
						<throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
							<maxDepthPerThrowable>30</maxDepthPerThrowable>
							<maxLength>4096</maxLength>
							<rootCauseFirst>true</rootCauseFirst>
						</throwableConverter>
					</stackTrace>
					<pattern>
						<pattern>{"service.name":"${springAppName}"}</pattern>
					</pattern>
				</providers>
			</encoder>
		</appender>
	</springProfile>

	<root level="INFO">
		<appender-ref ref="CONSOLE"/>
	</root>
</configuration>
