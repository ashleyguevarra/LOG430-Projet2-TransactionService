@startuml dss-transaction-flow
title DSS - Saga Transaction

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 230
skinparam sequenceGroupBorderColor #555555
skinparam sequenceGroupFontStyle italic
skinparam sequenceGroupBackgroundColor #F8F8F8
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #AAAAAA
}
skinparam participant {
    BackgroundColor White
    BorderColor Black
}

participant "Orchestrateur (.NET)" as Orch #FFE0B2
participant "Kafka" as Kafka #FFF9C4
participant "TransactionEventListener" as Listener #E3F2FD
participant "TransactionService" as TxSvc #E3F2FD
database "transaction-db" as DB
participant "OutboxPublisher (@Scheduled)" as Publisher

== Phase 1 - Demarrage ==

Orch -> Kafka : produce("transaction.created", payload)
activate Kafka
Kafka --> Orch : Ack
deactivate Kafka

Kafka -> Listener : consume "transaction.created"
activate Listener
Listener -> TxSvc : handleInboundKafkaEvent("transaction.created")
activate TxSvc

group TransactionService @Transactional
  TxSvc -> DB : INSERT transaction (status=CREATED)
  TxSvc -> DB : UPDATE transaction (status=CREATED_PENDING)
  TxSvc -> DB : INSERT outbox_events (topic=transaction.created.pending)
end

deactivate TxSvc
deactivate Listener

== Phase 2 - Publication CREATED_PENDING ==

Publisher -> DB : SELECT outbox_events WHERE published=false
DB --> Publisher : [transaction.created.pending]
Publisher -> Kafka : send("transaction.created.pending", payload)
activate Kafka
Kafka --> Publisher : Ack
deactivate Kafka
Publisher -> DB : UPDATE outbox_events SET published=true

== Phase 3 - Acceptation ==

Orch -> Kafka : produce("transaction.accepted", payload)
activate Kafka
Kafka --> Orch : Ack
deactivate Kafka

Kafka -> Listener : consume "transaction.accepted"
activate Listener
Listener -> TxSvc : handleInboundKafkaEvent("transaction.accepted")
activate TxSvc

group TransactionService @Transactional
  TxSvc -> DB : UPDATE transaction (status=ACCEPTED)
  TxSvc -> DB : UPDATE transaction (status=ACCEPTED_PENDING)
  TxSvc -> DB : INSERT outbox_events (topic=transaction.accepted.pending)
end

deactivate TxSvc
deactivate Listener

Publisher -> DB : SELECT outbox_events WHERE published=false
DB --> Publisher : [transaction.accepted.pending]
Publisher -> Kafka : send("transaction.accepted.pending", payload)
activate Kafka
Kafka --> Publisher : Ack
deactivate Kafka
Publisher -> DB : UPDATE outbox_events SET published=true

== Phase 4 - Etats terminaux consommes ==

Orch -> Kafka : produce("transaction.settled" | "transaction.refused" | "transaction.rejected" | "transaction.expired")
activate Kafka
Kafka --> Orch : Ack
deactivate Kafka

Kafka -> Listener : consume event terminal
activate Listener
Listener -> TxSvc : handleInboundKafkaEvent(topic)
activate TxSvc

alt topic = transaction.settled
  TxSvc -> DB : UPDATE status = SETTLED
else topic = transaction.refused OR transaction.failed
  TxSvc -> DB : UPDATE status = REFUSED
else topic = transaction.rejected
  TxSvc -> DB : UPDATE status = REJECTED
else topic = transaction.expired
  TxSvc -> DB : UPDATE status = EXPIRED
end

deactivate TxSvc
deactivate Listener

== Consultation ==

Orch -> TxSvc : GET /api/v2/transactions/{id}
activate TxSvc
TxSvc -> DB : SELECT * FROM transactions WHERE id=?
DB --> TxSvc : Transaction {id, status, amount, ...}
TxSvc --> Orch : 200 OK - TransactionResponse
deactivate TxSvc

@enduml
